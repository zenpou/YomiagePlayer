<Window x:Class="YomiagePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:ui="clr-namespace:YomiagePlayer.UI"
        Title="YomiagePlayer" Height="720" Width="1200"
        Background="#1E1E1E"
        AllowDrop="True" Drop="Window_Drop" PreviewDragOver="Window_PreviewDragOver">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#2B2B2B" Foreground="#EEE">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="ファイルを開く(_O)..." Click="OpenFile_Click"
                          InputGestureText="Ctrl+O" Foreground="Black" />
                <MenuItem Header="フォルダを開く(_D)..." Click="OpenFolder_Click" Foreground="Black" />
                <Separator />
                <MenuItem Header="終了(_X)" Click="Exit_Click" Foreground="Black" />
            </MenuItem>
            <MenuItem Header="設定(_S)" Click="Settings_Click" />
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="160" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="300" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- 左: ライブラリ / プレイリスト -->
            <Grid Grid.Column="0" Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ContentControl x:Name="LibraryHost" Grid.Row="0" />
                <ContentControl x:Name="PlaylistHost" Grid.Row="1" />
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#333" />

            <!-- 中央: 映像 + コントロール -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="Black">
                    <vlc:VideoView x:Name="VideoView">
                        <vlc:VideoView.Content>
                            <!-- Airspaceスパイクの結論: 映像上のD&D・表示はこの
                                 フローティングコンテンツ側で行う -->
                            <Grid Background="Transparent" AllowDrop="True"
                                  Drop="Window_Drop" DragOver="Window_PreviewDragOver">
                                <TextBlock x:Name="NowPlayingText" Foreground="#888" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Text="ファイルまたはフォルダを開いてください" />
                            </Grid>
                        </vlc:VideoView.Content>
                    </vlc:VideoView>
                </Grid>

                <ui:PlayerControls x:Name="Controls" Grid.Row="1" />
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#333" />

            <!-- 右: 歌詞パネル -->
            <ui:LyricsPane x:Name="Lyrics" Grid.Column="4" />
        </Grid>
    </DockPanel>
</Window>
