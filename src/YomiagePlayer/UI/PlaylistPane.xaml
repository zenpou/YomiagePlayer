<UserControl x:Class="YomiagePlayer.UI.PlaylistPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:vm="clr-namespace:YomiagePlayer.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PlaylistViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダ: タイトル + リピート/シャッフル -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10,8">
            <Grid>
                <TextBlock Text="プレイリスト" Foreground="#EEE" FontWeight="Bold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CycleRepeatModeCommand}" Width="30" Height="26"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip="リピート切替 (なし/全体/1曲)">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="🔁" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Opacity" Value="0.35" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RepeatMode}" Value="{x:Static vm:RepeatMode.All}">
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RepeatMode}" Value="{x:Static vm:RepeatMode.One}">
                                        <Setter Property="Content" Value="🔂" />
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding ToggleShuffleCommand}" Content="🔀" Width="30" Height="26"
                            BorderThickness="0" Cursor="Hand" ToolTip="シャッフル">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Opacity" Value="0.35" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShuffle}" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- リスト本体 -->
        <ListBox x:Name="List" Grid.Row="1"
                 ItemsSource="{Binding Items}"
                 dd:DragDrop.IsDragSource="True"
                 dd:DragDrop.IsDropTarget="True"
                 Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="List_MouseDoubleClick">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="削除" Click="Remove_Click" />
                    <MenuItem Header="再解析" Click="Reanalyze_Click" />
                    <Separator />
                    <MenuItem Header="エクスプローラーで表示" Click="ShowInExplorer_Click" />
                    <Separator />
                    <MenuItem Header="プレイリストを保存..." Click="Save_Click" />
                    <MenuItem Header="プレイリストを読み込み..." Click="Load_Click" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#252526" Padding="6,3" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Name, Converter={StaticResource FolderPathToName}}"
                                           Foreground="#9CDCFE" FontSize="11" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="▶" Foreground="#4FC1FF" FontSize="10"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#CCC"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Foreground" Value="#4FC1FF" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
