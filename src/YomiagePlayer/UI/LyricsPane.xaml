<UserControl x:Class="YomiagePlayer.UI.LyricsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:YomiagePlayer.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LyricsViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="#252526">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダ: 状態表示 -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10,8">
            <StackPanel>
                <TextBlock Text="歌詞 / 文章" Foreground="#EEE" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static vm:LyricsState.Analyzing}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ProgressBar Width="120" Height="10" Minimum="0" Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay}" VerticalAlignment="Center" />
                    <TextBlock Foreground="#AAA" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Run Text="解析中" /><Run Text="{Binding ProgressPercent, Mode=OneWay}" /><Run Text="%" />
                    </TextBlock>
                </StackPanel>
                <TextBlock Foreground="#888" Margin="0,4,0,0" Text="未解析">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static vm:LyricsState.Idle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel Margin="0,4,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="{x:Static vm:LyricsState.Failed}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Foreground="#F48771" TextWrapping="Wrap" Text="{Binding ErrorMessage}" />
                    <Button Content="再解析" Command="{Binding ReanalyzeCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,0" Padding="12,4" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 解析済み区間より先を再生中のバナー -->
        <Border Grid.Row="1" Background="#4B3A1E" Padding="10,6"
                Visibility="{Binding IsPositionAheadOfAnalysis, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="この区間は解析中です" Foreground="#E8C170" />
        </Border>

        <!-- 歌詞リスト -->
        <ListBox x:Name="LyricsList" Grid.Row="2"
                 ItemsSource="{Binding Rows}"
                 Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="4,1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3A3A3C" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" Foreground="#777"
                                   FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#BBB" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="Foreground" Value="#4FC1FF" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 現在行に戻る -->
        <Button Grid.Row="3" Content="▼ 現在行に戻る"
                Command="{Binding ResumeAutoScrollCommand}"
                Visibility="{Binding IsAutoScrollSuspended, Converter={StaticResource BoolToVis}}"
                Margin="10,6" Padding="8,4" />
    </Grid>
</UserControl>
